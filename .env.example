# Env vars for the three Routines.
# Add these in each Routine's "Environment Variables" section in the Routines dashboard.
# Do NOT commit a real .env file. .gitignore excludes it.

# === Routine 1: Daily Topic Scan ===

# YouTube Data API v3 key. Get from console.cloud.google.com -> Enable YouTube Data API v3 -> Create Credentials.
YOUTUBE_API_KEY=

# xAI / Grok API key. Get from console.x.ai. Optional. Skip if you don't have one.
XAI_API_KEY=

# === Routine 2: Pre-Call Sales Brief ===

# GoHighLevel Private Integration Token. Generate at GHL -> Settings -> Private Integrations.
# Scopes: View Contacts, View Contact Custom Fields, View Conversations, View Conversation Messages, View Calendars, View Calendar Events.
GHL_API_KEY=

# Your GHL sub-account Location ID. Find at GHL -> Settings -> Business Profile.
GHL_LOCATION_ID=

# Comma-separated list of GHL calendar IDs to scan for today's sales calls.
# For Ron: 6ogGwGObGeYiMKD5U3ur,TPgwkBAjvdu0hg0k0u0P (30-min + 60-min calls)
SALES_CALENDAR_IDS=

# === Routine 3: Fathom to Short-Form Scripts ===

# No env vars. Uses Fathom MCP + Slack MCP (both via Connectors).

# ============================================
# NOT NEEDED (handled by MCP Connectors instead):
# - Slack (Connectors UI)
# - Fathom (Connectors UI)
#
# Authorize both in claude.ai -> Settings -> Connectors before first Routine run.
# ============================================
